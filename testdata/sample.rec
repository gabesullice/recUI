# Library catalogue sample recfile
# Exercises: multiple types, %key:, %doc:, %type: rec/email/url/enum/uuid/date,
# multivalued fields, multi-line continuation, and a keyless type (Tag).

%rec: Author
%key: AuthorId
%doc: People who have written books in the catalogue.
%type: AuthorId uuid
%type: Email email
%type: Website url
%type: Born date

